# ==========================================
# Configurações de Ambiente (Exemplo)
# ==========================================

# Ambiente de execução (development, testing, production)
ENVIRONMENT=development

# Porta onde a API FastAPI vai correr (Defeito: 8000)
API_PORT=8000

# ==========================================
# Base de Dados
# ==========================================
# URL de ligação à base de dados. 
# Para SQLite local usar: sqlite:///./teoria_musical.db
DATABASE_URL=sqlite:///./teoria_musical.db

# ==========================================
# Segurança e Autenticação (Planeado para o futuro)
# ==========================================
# Chave secreta usada para assinar os tokens JWT (Login)
# Gerar uma chave forte em produção (ex: openssl rand -hex 32)
SECRET_KEY=aqui_entra_uma_chave_secreta_muito_longa_e_aleatoria

# Tempo de expiração do token de login (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30